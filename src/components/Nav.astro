---
const primaryLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/outreach', label: 'Outreach' },
  { href: '/trending', label: 'Trending' },
];

const utilityRight = [{ href: '/donate', label: 'Donate', goal: '$20K Goal' }];

const mobileLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/outreach', label: 'Outreach' },
  { href: '/trending', label: 'Trending' },
  { href: '/donate', label: 'Donate • $20K Goal' },
];
---

<header id="site-header" class="sticky top-0 z-50 border-b border-white/10 bg-black text-white">
  <div class="mx-auto w-full max-w-6xl px-4 md:px-8">
    <div class="flex items-center justify-between py-2 md:hidden">
      <a href="/">
        <img src="/brand/jIlbit-logo.png" alt="JILBIT" class="h-8 w-auto object-contain" loading="eager" decoding="async" />
      </a>
      <button
        id="mobile-menu-toggle"
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded border border-white/20 text-white"
        aria-expanded="false"
        aria-controls="mobile-menu-panel"
        aria-label="Toggle navigation menu"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M4 7H20M4 12H20M4 17H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        </svg>
      </button>
    </div>

    <nav id="mobile-menu-panel" class="hidden border-t border-white/10 py-3 md:hidden" aria-label="Mobile menu">
      <ul class="space-y-1">
        {
          mobileLinks.map(({ href, label }) => (
            <li>
              <a href={href} class={`block rounded px-2 py-2 text-sm transition hover:bg-white/10 ${label.includes('$20K Goal') ? 'text-[#5cd667]' : 'text-white/90'}`}>
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <script>
      const toggle = document.getElementById('mobile-menu-toggle');
      const panel = document.getElementById('mobile-menu-panel');
      if (toggle && panel) {
        toggle.addEventListener('click', () => {
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', expanded ? 'false' : 'true');
          panel.classList.toggle('hidden', expanded);
        });
      }
    </script>

    <div class="hidden md:block">
      <div class="desktop-top grid grid-cols-[auto_1fr_auto] items-center gap-2 py-2.5">
        <a href="/" class="justify-self-start">
          <img src="/brand/jIlbit-logo.png" alt="JILBIT" class="h-8 w-auto object-contain md:h-10" loading="eager" decoding="async" />
        </a>
        <div aria-hidden="true"></div>
        <nav class="flex flex-wrap items-center justify-end gap-x-3 text-[10px] font-medium uppercase tracking-[0.12em] text-white/75 md:gap-x-4" aria-label="Utility links">
          {
            utilityRight.map(({ href, label, goal }) => (
              <span class="inline-flex items-center gap-x-3">
                <a href={href} class="transition hover:text-white">
                  {label} • <span class="text-[#5cd667]">{goal}</span>
                </a>
              </span>
            ))
          }
        </nav>
      </div>
      <div class="relative left-1/2 w-screen -translate-x-1/2 border-b border-white/10" />

      <div class="desktop-bottom grid grid-cols-[auto_1fr_auto] items-center gap-3 py-3.5">
        <a href="/" class="desktop-bottom-logo transition">
          <img src="/brand/jIlbit-logo.png" alt="JILBIT" class="h-7 w-auto object-contain" loading="eager" decoding="async" />
        </a>

        <nav class="flex items-center justify-center overflow-x-auto" aria-label="Main">
          <ul class="flex min-w-0 flex-nowrap items-center justify-center gap-x-0 text-xs font-semibold uppercase tracking-[0.14em]">
            {
              primaryLinks.map(({ href, label }, i) => (
                <li class="flex items-center">
                  {i > 0 && <span class="mx-2 h-3 w-px shrink-0 bg-white/25 md:mx-4" aria-hidden="true" />}
                  <a href={href} class="whitespace-nowrap px-0.5 text-white/90 transition hover:text-white">
                    {label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <a href="/donate" class="desktop-bottom-donate text-[10px] font-medium uppercase tracking-[0.12em] text-white/75 transition hover:text-white">
          Donate • <span class="text-[#5cd667]">$20K Goal</span>
        </a>
      </div>
    </div>
  </div>

  <style>
    @media (min-width: 768px) {
      #site-header .desktop-top {
        max-height: 80px;
        opacity: 1;
        overflow: hidden;
        will-change: max-height, opacity, padding;
        transition: max-height 260ms ease, opacity 220ms ease, padding 260ms ease;
      }

      #site-header .desktop-top + div {
        opacity: 1;
        transition: opacity 220ms ease;
      }

      #site-header .desktop-bottom-logo,
      #site-header .desktop-bottom-donate {
        opacity: 0;
        visibility: hidden;
        transform: translateY(-4px);
        will-change: opacity, transform;
        transition: opacity 220ms ease, transform 220ms ease, visibility 220ms ease;
      }

      #site-header.desktop-compact .desktop-top {
        max-height: 0;
        opacity: 0;
        padding-top: 0;
        padding-bottom: 0;
      }

      #site-header.desktop-compact .desktop-top + div {
        opacity: 0;
        pointer-events: none;
      }

      #site-header.desktop-compact .desktop-bottom-logo,
      #site-header.desktop-compact .desktop-bottom-donate {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }
    }
  </style>

  <script>
    const desktopHeader = document.getElementById('site-header');
    const compactBreakpoint = 768;
    const compactEnterY = 320;
    const compactExitY = 260;
    let ticking = false;
    let isCompact = false;

    const updateDesktopHeader = () => {
      if (!desktopHeader) return;
      if (window.innerWidth < compactBreakpoint) {
        desktopHeader.classList.remove('desktop-compact');
        isCompact = false;
        return;
      }
      const y = window.scrollY;
      if (!isCompact && y >= compactEnterY) {
        isCompact = true;
        desktopHeader.classList.add('desktop-compact');
      } else if (isCompact && y <= compactExitY) {
        isCompact = false;
        desktopHeader.classList.remove('desktop-compact');
      }
    };

    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            updateDesktopHeader();
            ticking = false;
          });
          ticking = true;
        }
      },
      { passive: true }
    );
    window.addEventListener('resize', updateDesktopHeader);
    updateDesktopHeader();
  </script>
</header>
