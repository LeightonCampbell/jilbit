---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/home-magazine.css';
import { jamaicaFund, jamaicaFundProgress } from '../data/fundraising';
import { mayFundraiserEvent } from '../data/events';

const { goalAmount, raisedAmount } = jamaicaFund;
const { progressPercent } = jamaicaFundProgress;
---

<BaseLayout title="JILBIT — Faith for Real Life" description="Faith for real life. JILBIT is a Christian ministry rooted in Los Angeles, serving Jamaica and beyond.">
  <div class="home-magazine">
  <div class="hero">
    <div class="hero-grid">
      <a href="/trending" class="hero-main">
        <div class="img-wrap">
          <div class="ph ph-1"><span class="ph-icon">Features</span></div>
        </div>
        <div class="hero-main-body">
          <span class="tag">Theology · Cover Story</span>
          <h1>The Top 10 Questions Christians Are Still Debating — And What Jesus Said About Each</h1>
          <p>
            From predestination to prosperity gospel, believers wrestle with hard questions. The answers may be closer than we think.
          </p>
          <div class="byline">By Veronica Olson Neffinger · Read feature →</div>
        </div>
      </a>
      <a href="/trending" class="hero-side-top">
        <div>
          <div class="img-wrap">
            <div class="ph ph-4"><span class="ph-icon">C.L.</span></div>
          </div>
          <span class="tag green">Christian Living</span>
          <h3>What Should Christians Do When Government Feels Unstable?</h3>
          <div class="byline">By Peyton Garland</div>
        </div>
      </a>
      <a href="/trending" class="hero-side-bot">
        <div>
          <div class="img-wrap">
            <div class="ph ph-3"><span class="ph-icon">C.E.</span></div>
          </div>
          <span class="tag rust">Current Events</span>
          <h3>What Christians Should Understand About the Middle East Conflict</h3>
          <div class="byline">By Judy McEachran</div>
        </div>
      </a>
    </div>
  </div>

  <div class="action-strip" id="donate">
    <div class="action-strip-inner">
      <div class="action-block donate">
        <div class="eyebrow">Jamaica Mission Fundraiser</div>
        <h3>{mayFundraiserEvent.title} — Help Us Reach ${goalAmount.toLocaleString()}</h3>
        <p>
          {mayFundraiserEvent.dateLabel} · {mayFundraiserEvent.timeLabel} · {mayFundraiserEvent.location}. Every plate of jerk chicken, brown stew chicken, or fried fish funds the Jamaica mission directly.
        </p>
        <div class="progress-wrap">
          <div class="progress-row">
            <span>Mission Fund</span>
            <strong
              >${raisedAmount.toLocaleString()} of ${goalAmount.toLocaleString()} raised ({progressPercent}%)</strong
            >
          </div>
          <div class="progress-bar"><div class="progress-fill" style={`width: ${progressPercent}%`} /></div>
        </div>
        <div style="display:flex;gap:.8rem;flex-wrap:wrap">
          <a href={`tel:${mayFundraiserEvent.callPhoneHref}`} class="btn-gold-lg">Call to Preorder: {mayFundraiserEvent.callPhoneDisplay}</a>
          <a href={mayFundraiserEvent.orderUrl} class="btn-white-lg">Order Online</a>
        </div>
      </div>
      <div class="action-strip-divider" aria-hidden="true"></div>
      <div class="action-block mission" id="mission">
        <div class="eyebrow">Active &amp; Ongoing Mission</div>
        <h3>Be the Hands and Feet of Jesus in Jamaica</h3>
        <p>
          We are actively serving communities in Jamaica with the gospel, resources, and practical care. Whether you give, pray, or go — there is a place for you in this work.
        </p>
        <div style="display:flex;gap:.8rem;flex-wrap:wrap">
          <a href="/outreach" class="btn-gold-lg">Join the Mission</a>
          <a href="/blog/why-jamaica/" class="btn-white-lg">Learn More →</a>
        </div>
      </div>
    </div>
  </div>

  <div class="content-wrap">
    <div>
      <div class="jesus-feature" style="margin-bottom:2rem">
        <div class="eyebrow">Faith Meets the Headlines</div>
        <h2>Jesus Has a Word for Every Crisis We Face</h2>
        <p>
          Current events can feel overwhelming — war, economic anxiety, political chaos. But the Gospel speaks directly into each one. Explore how the teachings of Christ apply to what's happening right now.
        </p>
        <div class="jesus-links">
          <a href="/trending" class="jesus-link">
            <div>
              <div class="jesus-link-tag">Middle East Conflict</div>
              <h4>My Family Resisted Iran's Regime. My Hope Is Not in Foreign Intervention.</h4>
            </div>
          </a>
          <a href="/trending" class="jesus-link">
            <div>
              <div class="jesus-link-tag">Political Instability</div>
              <h4>What Should Christians Do When Government Feels Unstable?</h4>
            </div>
          </a>
          <a href="/trending" class="jesus-link">
            <div>
              <div class="jesus-link-tag">Technology &amp; Faith</div>
              <h4>Should Christians Use AI to Pray? A Biblical Framework</h4>
            </div>
          </a>
        </div>
      </div>

      <div class="topic-section">
        <div class="section-head">
          <h2>News</h2>
          <a href="/trending">View all →</a>
        </div>
        <div class="topic-three">
          <a href="/trending" class="topic-card">
            <div class="img-wrap"><div class="ph ph-4"><span class="ph-icon">News</span></div></div>
            <span class="tag">News</span>
            <h3>Beth Moore Is Leaving Her Ego Behind — And the Church Should Watch</h3>
            <div class="byline">By Bob Smietana</div>
          </a>
          <a href="/trending" class="topic-card">
            <div class="img-wrap"><div class="ph ph-7"><span class="ph-icon">News</span></div></div>
            <span class="tag">News</span>
            <h3>A New Approach to Native Missions Starts with the Past</h3>
            <div class="byline">By Janel Breitenstein</div>
          </a>
          <a href="/trending" class="topic-card">
            <div class="img-wrap"><div class="ph ph-3"><span class="ph-icon">News</span></div></div>
            <span class="tag">News</span>
            <h3>How Strait of Hormuz Closure Is Hurting Global Christian Aid</h3>
            <div class="byline">By Jill Nelson</div>
          </a>
        </div>
      </div>

      <hr class="divider" style="margin-bottom:2rem" />

      <div class="topic-section">
        <div class="section-head">
          <h2>Theology</h2>
          <a href="/trending">View all →</a>
        </div>
        <div class="article-list">
          <a href="/trending" class="art-row">
            <div class="art-thumb"><div class="ph ph-5"><span class="ph-icon">Th</span></div></div>
            <div class="art-body">
              <span class="tag">Theology</span>
              <h3>Did Jesus Die for Everyone? A Deep Dive into Atonement Theology</h3>
              <p>
                Christians have debated the scope of the atonement for centuries. Here's why the answer matters deeply — for evangelism, assurance, and the character of God.
              </p>
              <div class="byline">By Veronica Olson Neffinger</div>
            </div>
          </a>
          <a href="/trending" class="art-row">
            <div class="art-thumb"><div class="ph ph-8"><span class="ph-icon">Th</span></div></div>
            <div class="art-body">
              <span class="tag">Theology</span>
              <h3>What Is the Will of God? A Guide to Understanding Divine Purpose</h3>
              <p>We pray for it, seek it, and wrestle with it — but do we actually know what God's will is?</p>
              <div class="byline">Staff</div>
            </div>
          </a>
          <a href="/trending" class="art-row">
            <div class="art-thumb"><div class="ph ph-6"><span class="ph-icon">Th</span></div></div>
            <div class="art-body">
              <span class="tag">Theology</span>
              <h3>Why Does a Good God Allow Us to Suffer So Much?</h3>
              <p>Suffering is perhaps the oldest and hardest question in theology. Jesus doesn't give us an easy answer — but he gives us himself.</p>
              <div class="byline">Staff</div>
            </div>
          </a>
        </div>
      </div>

      <hr class="divider" style="margin-bottom:2rem" />

      <div class="topic-section">
        <div class="section-head">
          <h2>Christian Living</h2>
          <a href="/blog">View all →</a>
        </div>
        <div class="topic-three">
          <a href="/blog" class="topic-card">
            <div class="img-wrap"><div class="ph ph-2"><span class="ph-icon">C.L.</span></div></div>
            <span class="tag green">Christian Living</span>
            <h3>7 Warning Signs That Legalism Is Sneaking into Your Faith</h3>
            <div class="byline">Staff</div>
          </a>
          <a href="/blog" class="topic-card">
            <div class="img-wrap"><div class="ph ph-7"><span class="ph-icon">C.L.</span></div></div>
            <span class="tag green">Christian Living</span>
            <h3>5 Ways to Find God's Purpose for Your Life</h3>
            <div class="byline">Staff</div>
          </a>
          <a href="/blog" class="topic-card">
            <div class="img-wrap"><div class="ph ph-1"><span class="ph-icon">C.L.</span></div></div>
            <span class="tag green">Christian Living</span>
            <h3>5 Questions to Ask Yourself When You Feel Like Giving Up</h3>
            <div class="byline">Staff</div>
          </a>
        </div>
      </div>

      <hr class="divider" style="margin-bottom:2rem" />

      <div class="topic-section">
        <div class="section-head">
          <h2>Church</h2>
          <a href="/trending">View all →</a>
        </div>
        <div class="article-list">
          <a href="/trending" class="art-row">
            <div class="art-thumb"><div class="ph ph-5"><span class="ph-icon">Ch</span></div></div>
            <div class="art-body">
              <span class="tag rust">Church</span>
              <h3>The Seven Last Words of Jesus from the Cross Explained</h3>
              <p>Seven statements. Infinite depth. Understanding what Jesus said in his final hours changes everything about how we understand the gospel.</p>
              <div class="byline">Staff</div>
            </div>
          </a>
          <a href="/trending" class="art-row">
            <div class="art-thumb"><div class="ph ph-3"><span class="ph-icon">Ch</span></div></div>
            <div class="art-body">
              <span class="tag rust">Church</span>
              <h3>The Dark before the Dawn: The Significance of Holy Saturday</h3>
              <p>Between Good Friday's devastation and Easter's triumph lies a day of holy silence — and it has something profound to say to us today.</p>
              <div class="byline">Staff</div>
            </div>
          </a>
          <a href="/trending" class="art-row">
            <div class="art-thumb"><div class="ph ph-8"><span class="ph-icon">Ch</span></div></div>
            <div class="art-body">
              <span class="tag rust">Church</span>
              <h3>Why Is Maundy Thursday a Significant Part of Holy Week?</h3>
              <div class="byline">Staff</div>
            </div>
          </a>
        </div>
      </div>
    </div>

    <aside class="sidebar">
      <div class="verse-widget">
        <div class="vw-label">Verse of the Day</div>
        <blockquote>
          "Look to the LORD and his strength; seek his face always. Remember the wonders he has done, his miracles, and the judgments he pronounced."
        </blockquote>
        <cite>1 Chronicles 16:11–12</cite>
      </div>

      <div class="fundraiser-widget">
        <div class="fw-header">
          <div class="fw-eyebrow">Upcoming Event</div>
          <h3>{mayFundraiserEvent.title}</h3>
        </div>
        <div class="fw-body">
          <div class="meta">
            <strong>{mayFundraiserEvent.dateLabel} · {mayFundraiserEvent.timeLabel}</strong>
            {mayFundraiserEvent.location}
            <br />
            All proceeds → Jamaica Mission
          </div>
          <div class="fw-progress-label">
            <span>Raised</span>
            <strong>${raisedAmount.toLocaleString()} / ${goalAmount.toLocaleString()}</strong>
          </div>
          <div class="fw-bar"><div class="fw-fill" style={`width: ${progressPercent}%`} /></div>
          <div class="menu-items">
            {
              mayFundraiserEvent.menu.map((item) => {
                const [name, price] = item.split(' - ');
                return (
                  <div class="mi">
                    <span class="name">{name}</span>
                    <span class="price">{price}</span>
                  </div>
                );
              })
            }
          </div>
          <p class="fw-note">{mayFundraiserEvent.proceedsText}</p>
          <div class="fw-cta-row">
            <a href={`tel:${mayFundraiserEvent.callPhoneHref}`} class="fw-btn fw-btn-primary">Call to Order</a>
            <a href={mayFundraiserEvent.orderUrl} class="fw-btn fw-btn-outline">Order Online</a>
          </div>
        </div>
      </div>

      <div class="mission-widget">
        <div class="mw-label">Active Mission</div>
        <h3>Jamaica Outreach — Ongoing</h3>
        <p>
          We are actively on the ground in Jamaica, sharing the gospel and serving communities with tangible help. Your involvement makes the difference.
        </p>
        <div class="mission-stats">
          <div class="mstat">
            <div class="num">3</div>
            <div class="lbl">Communities</div>
          </div>
          <div class="mstat">
            <div class="num">2</div>
            <div class="lbl">Years Active</div>
          </div>
          <div class="mstat">
            <div class="num">100+</div>
            <div class="lbl">Families Served</div>
          </div>
        </div>
        <a href="/outreach" class="btn-mission">Get Involved →</a>
      </div>

      <div class="trending-widget">
        <div class="section-head">
          <h2>Trending Now</h2>
        </div>
        <ol class="trending-list">
          <li class="trending-item">
            <a href="/trending">
              <span class="t-num">01</span>
              <span class="t-title">Should Christians Use AI to Pray?</span>
            </a>
          </li>
          <li class="trending-item">
            <a href="/trending">
              <span class="t-num">02</span>
              <span class="t-title">Reclaim Your Peace and Replace Infinite Scrolling</span>
            </a>
          </li>
          <li class="trending-item">
            <a href="/trending">
              <span class="t-num">03</span>
              <span class="t-title">How Is the Conflict with Iran Affecting Everyday American Life?</span>
            </a>
          </li>
          <li class="trending-item">
            <a href="/trending">
              <span class="t-num">04</span>
              <span class="t-title">Why Are a Record Number of Americans Identifying as Political Moderates?</span>
            </a>
          </li>
          <li class="trending-item">
            <a href="/trending">
              <span class="t-num">05</span>
              <span class="t-title">Should We Reconsider How We Share the Gospel with Gen Z?</span>
            </a>
          </li>
        </ol>
      </div>

      <div id="newsletter" class="newsletter-widget">
        <h3>Stay Rooted in the Word</h3>
        <p>Get JILBIT's weekly roundup of faith, current events, and Jamaica mission updates delivered to your inbox.</p>
        <div class="nl-form">
          <input type="email" class="nl-input" placeholder="Your email address" name="email" autocomplete="email" />
          <a href="mailto:info@jilbit.com?subject=JILBIT%20newsletter%20signup" class="nl-btn">Subscribe — It's Free</a>
        </div>
      </div>
    </aside>
  </div>

  <section class="full-section">
    <div class="full-inner">
      <div class="section-head">
        <h2>Stories of Faith</h2>
        <a href="/blog">View all testimonies →</a>
      </div>
      <div class="testimony-grid">
        <a href="/blog" class="testimony-card">
          <div class="img-wrap"><div class="ph ph-2"><span class="ph-icon">T</span></div></div>
          <span class="tag">Testimony</span>
          <h3>I Ran from God and My Identity. Then I Read the New Testament.</h3>
          <p class="excerpt">A story of wandering, searching, and finally being found by the grace of Christ.</p>
          <span class="read-link">Read story →</span>
        </a>
        <a href="/blog" class="testimony-card">
          <div class="img-wrap"><div class="ph ph-6"><span class="ph-icon">T</span></div></div>
          <span class="tag">Testimony</span>
          <h3>Journalism Was My Religion. Then I Encountered Jesus Christ.</h3>
          <p class="excerpt">A reporter discovers that the greatest story he ever covered was the one happening inside him.</p>
          <span class="read-link">Read story →</span>
        </a>
        <a href="/blog/why-jamaica/" class="testimony-card">
          <div class="img-wrap"><div class="ph ph-4"><span class="ph-icon">T</span></div></div>
          <span class="tag green">Jamaica Mission</span>
          <h3>From Kingston to Crenshaw: How the Jamaica Mission Changed My Life</h3>
          <p class="excerpt">A volunteer's account of what they found when they answered the call to serve.</p>
          <span class="read-link">Read story →</span>
        </a>
      </div>
    </div>
  </section>
  </div>
</BaseLayout>
