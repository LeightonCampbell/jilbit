---
import BaseLayout from '../layouts/BaseLayout.astro';
import MissionCtaBand from '../components/MissionCtaBand.astro';
import { jamaicaFund, jamaicaFundProgress } from '../data/fundraising';

const { goalAmount, raisedAmount } = jamaicaFund;
const { remainingAmount, progressPercent } = jamaicaFundProgress;
---

<BaseLayout title="Donate | JILBIT" description="Partner with JILBIT through one-time or recurring giving.">
  <section class="relative overflow-hidden bg-[#000000] px-6 py-16 text-left md:py-24">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(201,146,42,0.14),transparent_55%)]" />
    <div class="content-shell relative">
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-[#5cd667]">Partner with us</p>
      <h1 class="mt-4 max-w-4xl text-4xl leading-tight text-[#faf7f2] md:text-6xl">See lives changed through your generosity.</h1>
      <p class="mt-6 max-w-2xl text-base text-[#faf7f2]/70 md:text-lg">
        Your gift helps us equip believers, support outreach initiatives, and fund the Summer Jamaica Outreach.
      </p>
    </div>
  </section>

  <section class="bg-[#f0ebe0] px-6 py-16 md:py-20">
    <div class="content-shell">
      <article class="rounded-lg border border-[rgba(92,61,46,0.15)] bg-white p-6 shadow-sm md:p-8">
        <div class="flex flex-wrap items-end justify-between gap-3">
          <h2 class="text-2xl leading-tight text-[#2e1a0e] md:text-3xl">Help us reach ${goalAmount.toLocaleString()} by July 2026</h2>
          <p class="text-sm font-medium text-[#7a6658]">{progressPercent}% funded</p>
        </div>
        <div class="mt-5 h-2.5 overflow-hidden rounded-full bg-[#f0ebe0]">
          <div class="h-full rounded-full bg-[#5cd667]" style={`width: ${progressPercent}%`} />
        </div>
        <p class="mt-4 text-sm text-[#7a6658]">
          <span class="font-semibold text-[#2e1a0e]">${raisedAmount.toLocaleString()}</span> raised ·
          <span class="font-semibold text-[#2e1a0e]">${remainingAmount.toLocaleString()}</span> remaining
        </p>
      </article>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        <article class="rounded-lg border border-[rgba(92,61,46,0.15)] bg-white p-6 md:p-8">
          <p class="text-xs font-medium uppercase tracking-[0.14em] text-[#c9922a]">Ways to give</p>
          <ul class="mt-4 space-y-3 text-[#7a6658]">
            <li>One-time mission support</li>
            <li>Monthly partnership giving</li>
            <li>Sponsorship for outreach supplies</li>
          </ul>
          <a
            href="mailto:info@jilbit.com"
            class="mt-6 inline-flex rounded bg-[#5cd667] px-6 py-3 text-sm font-medium text-[#2e1a0e] transition hover:brightness-95"
          >
            Contact for giving details
          </a>
        </article>
        <article class="rounded-lg border border-[rgba(92,61,46,0.15)] bg-white p-6 md:p-8">
          <p class="text-xs font-medium uppercase tracking-[0.14em] text-[#c9922a]">Mailing address</p>
          <p class="mt-4 leading-relaxed text-[#7a6658]">
            JILBIT Outreach Ministry
            <br />
            3843 South Crenshaw Blvd
            <br />
            Los Angeles, CA 90008
          </p>
          <p class="mt-4 text-sm text-[#7a6658]/90">Include your name and contact info so we can confirm receipt and thank you.</p>
        </article>
      </div>
    </div>
  </section>

  <MissionCtaBand heading="Thank you for standing with this mission" body="Every gift helps us serve with clarity, compassion, and gospel hope." />
</BaseLayout>
