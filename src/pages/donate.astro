---
import BaseLayout from '../layouts/BaseLayout.astro';
import { jamaicaFund, jamaicaFundProgress } from '../data/fundraising';

const { goalAmount, raisedAmount } = jamaicaFund;
const { remainingAmount, progressPercent } = jamaicaFundProgress;
---

<BaseLayout title="Donate | JILBIT" description="Partner with JILBIT through one-time or recurring giving.">
  <section class="content-shell py-24 md:py-32">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-zinc-500">Partner With Us</p>
    <h1 class="mt-4 max-w-4xl text-4xl tracking-tight text-zinc-900 md:text-6xl">See lives changed through your generosity.</h1>
    <p class="mt-6 max-w-2xl text-lg text-zinc-600">
      Your gift helps us equip believers, support outreach initiatives, and fund the Summer Jamaica Outreach.
    </p>
  </section>

  <section class="content-shell pb-24">
    <article class="mb-8 rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm md:p-8">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <h2 class="text-2xl text-zinc-900">Help us reach ${goalAmount.toLocaleString()} by July 2026</h2>
        <p class="text-sm text-zinc-600">{progressPercent}% funded</p>
      </div>
      <div class="mt-4 h-2.5 overflow-hidden rounded-full bg-zinc-200">
        <div class="h-full rounded-full bg-[#5cd667]" style={`width: ${progressPercent}%`} />
      </div>
      <p class="mt-3 text-sm text-zinc-600">
        <span class="font-medium text-zinc-900">${raisedAmount.toLocaleString()}</span> raised •
        <span class="font-medium text-zinc-900"> ${remainingAmount.toLocaleString()}</span> remaining
      </p>
    </article>
  </section>
</BaseLayout>
