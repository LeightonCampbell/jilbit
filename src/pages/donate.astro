---
import BaseLayout from '../layouts/BaseLayout.astro';
import MissionCtaBand from '../components/MissionCtaBand.astro';
import { jamaicaFund, jamaicaFundProgress } from '../data/fundraising';

const { goalAmount, raisedAmount } = jamaicaFund;
const { remainingAmount, progressPercent } = jamaicaFundProgress;

const usStates = [
  ['', 'State'],
  ['AL', 'Alabama'],
  ['AK', 'Alaska'],
  ['AZ', 'Arizona'],
  ['AR', 'Arkansas'],
  ['CA', 'California'],
  ['CO', 'Colorado'],
  ['CT', 'Connecticut'],
  ['DE', 'Delaware'],
  ['DC', 'District of Columbia'],
  ['FL', 'Florida'],
  ['GA', 'Georgia'],
  ['HI', 'Hawaii'],
  ['ID', 'Idaho'],
  ['IL', 'Illinois'],
  ['IN', 'Indiana'],
  ['IA', 'Iowa'],
  ['KS', 'Kansas'],
  ['KY', 'Kentucky'],
  ['LA', 'Louisiana'],
  ['ME', 'Maine'],
  ['MD', 'Maryland'],
  ['MA', 'Massachusetts'],
  ['MI', 'Michigan'],
  ['MN', 'Minnesota'],
  ['MS', 'Mississippi'],
  ['MO', 'Missouri'],
  ['MT', 'Montana'],
  ['NE', 'Nebraska'],
  ['NV', 'Nevada'],
  ['NH', 'New Hampshire'],
  ['NJ', 'New Jersey'],
  ['NM', 'New Mexico'],
  ['NY', 'New York'],
  ['NC', 'North Carolina'],
  ['ND', 'North Dakota'],
  ['OH', 'Ohio'],
  ['OK', 'Oklahoma'],
  ['OR', 'Oregon'],
  ['PA', 'Pennsylvania'],
  ['RI', 'Rhode Island'],
  ['SC', 'South Carolina'],
  ['SD', 'South Dakota'],
  ['TN', 'Tennessee'],
  ['TX', 'Texas'],
  ['UT', 'Utah'],
  ['VT', 'Vermont'],
  ['VA', 'Virginia'],
  ['WA', 'Washington'],
  ['WV', 'West Virginia'],
  ['WI', 'Wisconsin'],
  ['WY', 'Wyoming'],
];
---

<BaseLayout title="Donate | JILBIT" description="Partner with JILBIT through one-time or recurring giving.">
  <section class="relative overflow-hidden bg-[#000000] px-6 py-16 text-left md:py-24">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(201,146,42,0.14),transparent_55%)]" />
    <div class="content-shell relative max-w-4xl">
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-[#5cd667]">Partner with us</p>
      <h1 class="mt-4 text-4xl leading-tight text-[#faf7f2] md:text-5xl lg:text-6xl">See lives changed through your generosity.</h1>
      <p class="mt-6 text-base leading-relaxed text-[#faf7f2]/70 md:text-lg">
        In a world that needs the hope of Christ, your generosity helps JILBIT equip believers, serve in Jamaica, and share the gospel
        with clarity and compassion.
      </p>
    </div>
  </section>

  <section class="bg-[#f0ebe0] px-6 py-12 md:py-16">
    <div class="content-shell max-w-6xl">
      <article class="rounded-lg border border-[rgba(92,61,46,0.15)] bg-white p-6 shadow-sm md:p-8">
        <div class="flex flex-wrap items-end justify-between gap-3">
          <h2 class="text-xl font-medium text-[#2e1a0e] md:text-2xl">Mission goal · July 2026</h2>
          <p class="text-sm font-medium text-[#7a6658]">{progressPercent}% funded</p>
        </div>
        <div class="mt-4 h-2.5 overflow-hidden rounded-full bg-[#f0ebe0]">
          <div class="h-full rounded-full bg-[#5cd667]" style={`width: ${progressPercent}%`} />
        </div>
        <p class="mt-3 text-sm text-[#7a6658]">
          <span class="font-semibold text-[#2e1a0e]">${raisedAmount.toLocaleString()}</span> raised of
          <span class="font-semibold text-[#2e1a0e]">${goalAmount.toLocaleString()}</span>
          · <span class="font-medium text-[#2e1a0e]">${remainingAmount.toLocaleString()}</span> to go
        </p>
      </article>

      <div class="mt-10 lg:grid lg:grid-cols-[1fr_320px] lg:gap-10 lg:items-start">
        <article class="rounded-lg border border-[rgba(92,61,46,0.15)] bg-white p-6 shadow-sm md:p-8 lg:p-10">
          <p class="text-xs font-medium uppercase tracking-[0.12em] text-[#7a6658]">
            Required fields are marked <span class="text-[#ff2828]">*</span>
          </p>

          <form id="donation-form" class="mt-8 space-y-10" novalidate>
            <div class="flex items-center gap-2 text-xs font-medium uppercase tracking-[0.12em] text-[#7a6658]">
              <span id="step-indicator-1" class="rounded-full bg-[#2d4a3e] px-3 py-1 text-white">1. Gift</span>
              <span id="step-indicator-2" class="rounded-full border border-[rgba(92,61,46,0.2)] px-3 py-1">2. Billing</span>
              <span id="step-indicator-3" class="rounded-full border border-[rgba(92,61,46,0.2)] px-3 py-1">3. Payment</span>
            </div>

            <div id="step-1" class="space-y-10">
            <fieldset class="space-y-4">
              <legend class="text-base font-medium text-[#2e1a0e]">Select a gift amount <span class="text-[#ff2828]">*</span></legend>
              <div class="grid grid-cols-2 gap-3 sm:grid-cols-4">
                {
                  [250, 100, 50].map((amt) => (
                    <label class="relative flex cursor-pointer">
                      <input type="radio" name="giftAmount" value={String(amt)} class="peer sr-only" />
                      <span class="flex w-full items-center justify-center rounded-lg border border-[rgba(92,61,46,0.2)] bg-[#faf7f2]/50 px-4 py-3.5 text-center text-sm font-medium text-[#2e1a0e] transition peer-checked:border-[#5cd667] peer-checked:bg-[#5cd667]/15 peer-checked:ring-1 peer-checked:ring-[#5cd667]/40 peer-focus-visible:ring-2 peer-focus-visible:ring-[#5cd667]">
                        ${amt}
                      </span>
                    </label>
                  ))
                }
                <label class="relative col-span-2 flex cursor-pointer sm:col-span-1">
                  <input type="radio" name="giftAmount" value="other" id="gift-other-radio" class="peer sr-only" />
                  <span class="flex w-full items-center justify-center rounded-lg border border-[rgba(92,61,46,0.2)] bg-[#faf7f2]/50 px-4 py-3.5 text-center text-sm font-medium text-[#2e1a0e] transition peer-checked:border-[#5cd667] peer-checked:bg-[#5cd667]/15 peer-checked:ring-1 peer-checked:ring-[#5cd667]/40">
                    Other
                  </span>
                </label>
              </div>
              <div id="other-amount-wrap" class="hidden">
                <label class="block text-sm font-medium text-[#2e1a0e]">
                  Enter amount (USD)
                  <input
                    type="number"
                    name="otherAmount"
                    id="other-amount"
                    min="1"
                    step="0.01"
                    placeholder="0.00"
                    class="mt-2 w-full max-w-xs rounded-lg border border-[rgba(92,61,46,0.2)] bg-white px-4 py-3 text-[#2e1a0e] outline-none focus:border-[#5c3d2e]"
                  />
                </label>
              </div>
            </fieldset>

            <fieldset class="space-y-4">
              <legend class="text-base font-medium text-[#2e1a0e]">Gift type <span class="text-[#ff2828]">*</span></legend>
              <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap">
                <label class="flex cursor-pointer items-center gap-3 rounded-lg border border-[rgba(92,61,46,0.15)] px-4 py-3 text-sm text-[#7a6658] has-[:checked]:border-[#5cd667] has-[:checked]:bg-[#5cd667]/10">
                  <input type="radio" name="giftType" value="one-time" checked class="text-[#5cd667] focus:ring-[#5cd667]" />
                  One-time gift
                </label>
                <label class="flex cursor-pointer items-center gap-3 rounded-lg border border-[rgba(92,61,46,0.15)] px-4 py-3 text-sm text-[#7a6658] has-[:checked]:border-[#5cd667] has-[:checked]:bg-[#5cd667]/10">
                  <input type="radio" name="giftType" value="recurring" class="text-[#5cd667] focus:ring-[#5cd667]" />
                  Recurring gift
                </label>
              </div>
              <div id="recurring-wrap" class="hidden space-y-2">
                <label class="block text-sm font-medium text-[#2e1a0e]" for="recurring-duration">Duration</label>
                <select
                  name="recurringDuration"
                  id="recurring-duration"
                  class="w-full max-w-md rounded-lg border border-[rgba(92,61,46,0.2)] bg-white px-4 py-3 text-sm text-[#2e1a0e] outline-none focus:border-[#5c3d2e] sm:w-auto sm:min-w-[280px]"
                >
                  <option value="monthly-ongoing">Ongoing (monthly)</option>
                  <option value="monthly-2">2 months</option>
                  <option value="quarterly-ongoing">Ongoing (quarterly)</option>
                  <option value="quarterly-2">2 quarters</option>
                  <option value="yearly">Annual</option>
                </select>
              </div>
            </fieldset>

            <fieldset class="space-y-3">
              <legend class="sr-only">Gift options</legend>
              <label class="flex cursor-pointer items-start gap-3 text-sm text-[#7a6658]">
                <input type="checkbox" name="anonymous" class="mt-1 rounded border-[rgba(92,61,46,0.3)] text-[#5cd667] focus:ring-[#5cd667]" />
                <span>I would like this gift to be listed as anonymous in public recognition (we will still record it privately).</span>
              </label>
              <label class="flex cursor-pointer items-start gap-3 text-sm text-[#7a6658]">
                <input type="checkbox" name="honorGift" id="honor-gift" class="mt-1 rounded border-[rgba(92,61,46,0.3)] text-[#5cd667] focus:ring-[#5cd667]" />
                <span>This is an honor or memorial gift.</span>
              </label>
              <div id="honor-wrap" class="hidden space-y-3 rounded-lg border border-[rgba(92,61,46,0.12)] bg-[#faf7f2]/40 p-4">
                <div class="flex flex-wrap gap-4">
                  <label class="flex items-center gap-2 text-sm text-[#7a6658]">
                    <input type="radio" name="honorType" value="in-memory" class="text-[#5cd667]" />
                    In memory of
                  </label>
                  <label class="flex items-center gap-2 text-sm text-[#7a6658]">
                    <input type="radio" name="honorType" value="in-honor" class="text-[#5cd667]" />
                    In honor of
                  </label>
                </div>
                <div class="grid gap-3 sm:grid-cols-2">
                  <label class="text-sm">
                    <span class="font-medium text-[#2e1a0e]">Honoree first name</span>
                    <input type="text" name="honoreeFirst" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-3 py-2 text-[#2e1a0e]" />
                  </label>
                  <label class="text-sm">
                    <span class="font-medium text-[#2e1a0e]">Honoree last name</span>
                    <input type="text" name="honoreeLast" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-3 py-2 text-[#2e1a0e]" />
                  </label>
                </div>
              </div>
            </fieldset>

            <div>
              <label class="text-sm font-medium text-[#2e1a0e]" for="comments">Comments</label>
              <textarea
                name="comments"
                id="comments"
                rows="4"
                class="mt-2 w-full rounded-lg border border-[rgba(92,61,46,0.2)] bg-[#faf7f2]/30 px-4 py-3 text-[#7a6658] outline-none focus:border-[#5c3d2e]"
                placeholder="Optional message to our team"
              />
            </div>

            <div class="flex w-full justify-center gap-3 border-t border-[rgba(92,61,46,0.1)] pt-8">
              <button
                type="button"
                id="next-step-1"
                class="w-full max-w-md rounded bg-[#5cd667] px-8 py-3.5 text-center text-sm font-medium text-[#2e1a0e] transition hover:brightness-95"
              >
                Continue to Billing
              </button>
            </div>
            </div>

            <div id="step-2" class="hidden space-y-8">
            <div>
              <h2 class="text-lg font-medium text-[#2e1a0e]">Billing information</h2>
              <p class="mt-1 text-sm text-[#7a6658]">We use this for your secure receipt and payment verification.</p>
              <div class="mt-6 space-y-4">
                <label class="flex cursor-pointer items-center gap-3 text-sm text-[#7a6658]">
                  <input type="checkbox" name="onBehalfOrg" id="on-behalf-org" class="rounded border-[rgba(92,61,46,0.3)] text-[#5cd667]" />
                  Make this gift on behalf of an organization
                </label>
                <div id="org-name-wrap" class="hidden">
                  <label class="text-sm font-medium text-[#2e1a0e]">
                    Organization name <span class="text-[#ff2828]">*</span>
                    <input type="text" name="organizationName" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-4 py-3" />
                  </label>
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="text-sm">
                    <span class="font-medium text-[#2e1a0e]">First name <span class="text-[#ff2828]">*</span></span>
                    <input required name="firstName" type="text" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-4 py-3 text-[#2e1a0e]" />
                  </label>
                  <label class="text-sm">
                    <span class="font-medium text-[#2e1a0e]">Last name <span class="text-[#ff2828]">*</span></span>
                    <input required name="lastName" type="text" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-4 py-3 text-[#2e1a0e]" />
                  </label>
                </div>
                <label class="block text-sm">
                  <span class="font-medium text-[#2e1a0e]">Street address <span class="text-[#ff2828]">*</span></span>
                  <input required name="street1" type="text" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-4 py-3" />
                </label>
                <label class="block text-sm">
                  <span class="font-medium text-[#2e1a0e]">Street address 2</span>
                  <input name="street2" type="text" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-4 py-3" />
                </label>
                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="text-sm">
                    <span class="font-medium text-[#2e1a0e]">City <span class="text-[#ff2828]">*</span></span>
                    <input required name="city" type="text" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-4 py-3" />
                  </label>
                  <label class="text-sm">
                    <span class="font-medium text-[#2e1a0e]">State <span class="text-[#ff2828]">*</span></span>
                    <select required name="state" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] bg-white px-4 py-3 text-[#2e1a0e]">
                      {usStates.map(([val, label]) => (
                        <option value={val}>{label}</option>
                      ))}
                    </select>
                  </label>
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="text-sm">
                    <span class="font-medium text-[#2e1a0e]">ZIP / Postal code <span class="text-[#ff2828]">*</span></span>
                    <input required name="zip" type="text" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-4 py-3" />
                  </label>
                  <label class="text-sm">
                    <span class="font-medium text-[#2e1a0e]">Country <span class="text-[#ff2828]">*</span></span>
                    <select name="country" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] bg-white px-4 py-3 text-[#2e1a0e]">
                      <option value="US">United States</option>
                      <option value="CA">Canada</option>
                      <option value="JM">Jamaica</option>
                      <option value="other">Other</option>
                    </select>
                  </label>
                </div>
                <div class="grid gap-4 sm:grid-cols-2">
                  <label class="text-sm">
                    <span class="font-medium text-[#2e1a0e]">Phone <span class="text-[#ff2828]">*</span></span>
                    <input required name="phone" type="tel" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-4 py-3" />
                  </label>
                  <label class="text-sm">
                    <span class="font-medium text-[#2e1a0e]">Email <span class="text-[#ff2828]">*</span></span>
                    <input required name="email" type="email" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-4 py-3" />
                  </label>
                </div>
                <p class="text-xs text-[#7a6658]">
                  You will receive a gift acknowledgment by email. You can ask us to adjust how often we follow up.
                </p>
              </div>
            </div>
            <div class="flex gap-3 border-t border-[rgba(92,61,46,0.1)] pt-8">
              <button type="button" id="back-step-2" class="flex-1 rounded border border-[#5c3d2e] px-8 py-3.5 text-center text-sm font-medium text-[#5c3d2e] transition hover:bg-[#faf7f2]">
                Back
              </button>
              <button
                type="button"
                id="next-step-2"
                class="flex-1 rounded bg-[#5cd667] px-8 py-3.5 text-center text-sm font-medium text-[#2e1a0e] transition hover:brightness-95"
              >
                Continue to Payment
              </button>
            </div>
            </div>

            <div id="step-3" class="hidden space-y-8">
              <div>
                <h2 class="text-lg font-medium text-[#2e1a0e]">Payment gateway</h2>
                <p class="mt-1 text-sm text-[#7a6658]">Your donation is submitted through a secure encrypted payment gateway.</p>
                <div class="mt-6 grid gap-4 sm:grid-cols-2">
                  <label class="text-sm sm:col-span-2">
                    <span class="font-medium text-[#2e1a0e]">Name on card <span class="text-[#ff2828]">*</span></span>
                    <input data-step-required="3" name="cardName" type="text" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-4 py-3" />
                  </label>
                  <label class="text-sm sm:col-span-2">
                    <span class="font-medium text-[#2e1a0e]">Card number <span class="text-[#ff2828]">*</span></span>
                    <input data-step-required="3" name="cardNumber" inputmode="numeric" autocomplete="cc-number" type="text" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-4 py-3" />
                  </label>
                  <label class="text-sm">
                    <span class="font-medium text-[#2e1a0e]">Expiry (MM/YY) <span class="text-[#ff2828]">*</span></span>
                    <input data-step-required="3" name="cardExpiry" autocomplete="cc-exp" type="text" placeholder="MM/YY" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-4 py-3" />
                  </label>
                  <label class="text-sm">
                    <span class="font-medium text-[#2e1a0e]">CVV <span class="text-[#ff2828]">*</span></span>
                    <input data-step-required="3" name="cardCvv" inputmode="numeric" autocomplete="cc-csc" type="password" class="mt-1 w-full rounded-lg border border-[rgba(92,61,46,0.2)] px-4 py-3" />
                  </label>
                </div>
                <p class="mt-3 text-xs text-[#7a6658]">Donations are tax-deductible to the extent allowed by law. A receipt will be emailed immediately after completion.</p>
              </div>
            </div>

            <p id="donate-form-error" class="hidden rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800"></p>
            <p id="donate-form-success" class="hidden rounded-lg border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800"></p>

            <div class="flex gap-3 border-t border-[rgba(92,61,46,0.1)] pt-8">
              <button type="button" id="back-step-3" class="hidden flex-1 rounded border border-[#5c3d2e] px-8 py-3.5 text-center text-sm font-medium text-[#5c3d2e] transition hover:bg-[#faf7f2]">
                Back
              </button>
              <button
                type="submit"
                id="complete-donation-btn"
                class="hidden flex-1 rounded bg-[#5cd667] px-8 py-3.5 text-center text-sm font-medium text-[#2e1a0e] transition hover:brightness-95"
              >
                Submit
              </button>
            </div>
            <p class="text-xs leading-relaxed text-[#7a6658]">
              Your gift is processed as a secure online payment. Billing information is transmitted over encrypted connections, and you will receive an email confirmation for your records.
            </p>
          </form>
        </article>

        <aside class="mt-10 space-y-6 lg:mt-0">
          <article class="rounded-lg border border-[rgba(92,61,46,0.15)] bg-white p-6 shadow-sm">
            <h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-[#2e1a0e]">Would you like more information?</h2>
            <p class="mt-3 text-sm leading-relaxed text-[#7a6658]">
              Contact us about partnerships, recurring giving, or mission sponsorship.
            </p>
            <a href="mailto:info@jilbit.com" class="mt-4 inline-block text-sm font-medium text-[#2d4a3e] underline underline-offset-4 hover:text-[#2e1a0e]">
              info@jilbit.com
            </a>
          </article>
          <article class="rounded-lg border border-[rgba(92,61,46,0.15)] bg-white p-6 shadow-sm">
            <h2 class="text-sm font-semibold uppercase tracking-[0.12em] text-[#2e1a0e]">Give by check</h2>
            <p class="mt-3 text-sm leading-relaxed text-[#7a6658]">
              JILBIT<br />
              2414 Virginia Road<br />
              Los Angeles, CA 90016
            </p>
            <p class="mt-3 text-xs text-[#7a6658]">Include a note with your name and email so we can thank you and send a receipt.</p>
          </article>
          <p class="text-xs leading-relaxed text-[#7a6658]">
            Your donation is tax-deductible to the extent allowed by law. JILBIT provides acknowledgment receipts for charitable giving records.
          </p>
        </aside>
      </div>
    </div>
  </section>

  <MissionCtaBand heading="Thank you for standing with this mission" body="Every gift helps us serve with clarity, compassion, and gospel hope." />
</BaseLayout>

<script>
  const form = document.getElementById('donation-form');
  const errEl = document.getElementById('donate-form-error');
  const successEl = document.getElementById('donate-form-success');
  const otherWrap = document.getElementById('other-amount-wrap');
  const otherInput = document.getElementById('other-amount');
  const recurringWrap = document.getElementById('recurring-wrap');
  const honorWrap = document.getElementById('honor-wrap');
  const honorGift = document.getElementById('honor-gift');
  const onBehalfOrg = document.getElementById('on-behalf-org');
  const orgNameWrap = document.getElementById('org-name-wrap');
  const step1 = document.getElementById('step-1');
  const step2 = document.getElementById('step-2');
  const step3 = document.getElementById('step-3');
  const stepIndicators = [1, 2, 3].map((n) => document.getElementById(`step-indicator-${n}`));
  const nextStep1 = document.getElementById('next-step-1');
  const nextStep2 = document.getElementById('next-step-2');
  const backStep2 = document.getElementById('back-step-2');
  const backStep3 = document.getElementById('back-step-3');
  const completeDonationBtn = document.getElementById('complete-donation-btn');
  let currentStep = 1;

  function setError(message) {
    if (!errEl) return;
    errEl.textContent = message;
    errEl.classList.remove('hidden');
  }

  function clearMessages() {
    if (errEl) errEl.classList.add('hidden');
    if (successEl) successEl.classList.add('hidden');
  }

  function showStep(stepNumber) {
    currentStep = stepNumber;
    step1?.classList.toggle('hidden', stepNumber !== 1);
    step2?.classList.toggle('hidden', stepNumber !== 2);
    step3?.classList.toggle('hidden', stepNumber !== 3);
    if (backStep3) backStep3.classList.toggle('hidden', stepNumber !== 3);
    if (completeDonationBtn) completeDonationBtn.classList.toggle('hidden', stepNumber !== 3);

    stepIndicators.forEach((chip, idx) => {
      if (!chip) return;
      const isActive = idx + 1 === stepNumber;
      chip.classList.toggle('bg-[#2d4a3e]', isActive);
      chip.classList.toggle('text-white', isActive);
      chip.classList.toggle('border', !isActive);
      chip.classList.toggle('border-[rgba(92,61,46,0.2)]', !isActive);
    });
    clearMessages();
  }

  function validateStep(stepNumber) {
    if (stepNumber === 1) {
      const selectedAmount = document.querySelector('input[name="giftAmount"]:checked');
      if (!selectedAmount) {
        setError('Please select a gift amount.');
        return false;
      }
      if ('value' in selectedAmount && selectedAmount.value === 'other') {
        const other = String(new FormData(form).get('otherAmount') || '').trim();
        if (!other || Number(other) <= 0) {
          setError('Please enter a valid amount for "Other."');
          return false;
        }
      }
      const selectedType = document.querySelector('input[name="giftType"]:checked');
      if (!selectedType) {
        setError('Please select a gift type.');
        return false;
      }
      return true;
    }

    if (stepNumber === 2) {
      if (!(form instanceof HTMLFormElement)) return false;
      const fd = new FormData(form);
      const requiredFields = ['firstName', 'lastName', 'street1', 'city', 'state', 'zip', 'country', 'phone', 'email'];
      for (const fieldName of requiredFields) {
        if (!String(fd.get(fieldName) || '').trim()) {
          setError('Please complete all required billing fields.');
          return false;
        }
      }
      if (fd.get('onBehalfOrg') && !String(fd.get('organizationName') || '').trim()) {
        setError('Please enter the organization name, or uncheck "on behalf of an organization."');
        return false;
      }
      return true;
    }

    if (stepNumber === 3) {
      if (!(form instanceof HTMLFormElement)) return false;
      const fd = new FormData(form);
      const paymentFields = ['cardName', 'cardNumber', 'cardExpiry', 'cardCvv'];
      for (const fieldName of paymentFields) {
        if (!String(fd.get(fieldName) || '').trim()) {
          setError('Please complete all required payment fields.');
          return false;
        }
      }
      return true;
    }

    return true;
  }

  function syncAmountUI() {
    const selected = document.querySelector('input[name="giftAmount"]:checked');
    const showOther = selected && 'value' in selected && selected.value === 'other';
    otherWrap?.classList.toggle('hidden', !showOther);
    if (showOther && otherInput instanceof HTMLInputElement) otherInput.focus();
  }

  function syncGiftType() {
    const gt = document.querySelector('input[name="giftType"]:checked');
    const recurring = gt && 'value' in gt && gt.value === 'recurring';
    recurringWrap?.classList.toggle('hidden', !recurring);
  }

  document.querySelectorAll('input[name="giftAmount"]').forEach((el) => {
    el.addEventListener('change', syncAmountUI);
  });
  document.querySelectorAll('input[name="giftType"]').forEach((el) => {
    el.addEventListener('change', syncGiftType);
  });
  honorGift?.addEventListener('change', () => {
    const checked = honorGift instanceof HTMLInputElement && honorGift.checked;
    honorWrap?.classList.toggle('hidden', !checked);
  });
  onBehalfOrg?.addEventListener('change', () => {
    const checked = onBehalfOrg instanceof HTMLInputElement && onBehalfOrg.checked;
    orgNameWrap?.classList.toggle('hidden', !checked);
  });
  nextStep1?.addEventListener('click', () => {
    if (validateStep(1)) showStep(2);
  });
  nextStep2?.addEventListener('click', () => {
    if (validateStep(2)) showStep(3);
  });
  backStep2?.addEventListener('click', () => showStep(1));
  backStep3?.addEventListener('click', () => showStep(2));

  syncAmountUI();
  syncGiftType();
  showStep(1);

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    clearMessages();
    if (!validateStep(currentStep)) return;
    if (!validateStep(1) || !validateStep(2) || !validateStep(3)) return;

    if (successEl) {
      successEl.textContent =
        'Donation completed successfully. Your secure payment was submitted and a tax-deductible receipt will be sent to your email.';
      successEl.classList.remove('hidden');
    }
    if (form instanceof HTMLFormElement) form.reset();
    syncAmountUI();
    syncGiftType();
    showStep(1);
  });
</script>


