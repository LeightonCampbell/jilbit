---
import BaseLayout from '../layouts/BaseLayout.astro';
import MissionCtaBand from '../components/MissionCtaBand.astro';
---

<BaseLayout title="Projects | JILBIT" description="JILBIT ministry projects in Jamaica.">
  <section class="relative overflow-hidden bg-[#000000] px-6 py-16 text-left md:py-24">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(201,146,42,0.14),transparent_55%)]" />
    <div class="content-shell relative max-w-4xl">
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-[#5cd667]">Ministry projects</p>
      <h1 class="mt-4 text-4xl leading-tight text-[#faf7f2] md:text-5xl lg:text-6xl">Projects</h1>
    </div>
  </section>

  <section class="bg-[#f0ebe0] px-6 py-16 md:py-20">
    <div class="content-shell">
      <article class="rounded-lg border border-[rgba(92,61,46,0.15)] bg-white p-6 shadow-sm md:p-8 lg:p-10">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[#c9922a]">First project</p>
        <h2 class="mt-3 text-3xl leading-tight text-[#2e1a0e] md:text-4xl">Better Home</h2>
        <p class="mt-4 max-w-4xl text-[#7a6658]">
          Better Home is focused on creating children's homes in Jamaica, starting in Linstead, Saint Catherine, Jamaica. The
          vision is to build a Children's Haven that is better than what many call "home" and support children from birth through
          adulthood.
        </p>
      </article>
    </div>
  </section>

  <MissionCtaBand heading="Support Better Home" body="Help us build a safe Children's Haven for generations to come." />
</BaseLayout>
