---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Trending | JILBIT" description="Trending Christian topics and faith conversations curated by JILBIT.">
  <section class="content-shell py-20 md:py-24">
    <h1 class="text-4xl tracking-tight text-zinc-900 md:text-6xl">Here's What's Trending Today...</h1>
  </section>

  <section class="content-shell pb-20">
    <ol class="space-y-4 rounded-3xl border border-zinc-200 bg-white p-8">
      {[
        'Should Christians Use AI to Pray?',
        'Reclaim Your Peace and Replace Infinite Scrolling',
        'How Is the Conflict with Iran Affecting Everyday American Life?',
        'Why Are a Record Number of Americans Identifying as Political Moderates?',
        'Should We Reconsider How We Share the Gospel with Gen Z?',
      ].map((title, idx) => (
        <li class="flex gap-3 border-b border-zinc-200 pb-3 last:border-none">
          <span class="text-sm font-semibold text-zinc-500">{String(idx + 1).padStart(2, '0')}</span>
          <span class="text-zinc-800">{title}</span>
        </li>
      ))}
    </ol>
  </section>
</BaseLayout>
