---
import BaseLayout from '../layouts/BaseLayout.astro';
import { jamaicaFund, jamaicaFundProgress } from '../data/fundraising';
import { mayFundraiserEvent } from '../data/events';

const { goalAmount, raisedAmount } = jamaicaFund;
const { remainingAmount, progressPercent } = jamaicaFundProgress;
---

<BaseLayout title="Summer Jamaica Outreach 2026 | JILBIT" description="Support and join JILBIT's Summer Jamaica Outreach in July 2026.">
  <section class="content-shell py-32">
    <p class="text-sm uppercase tracking-[0.2em] text-zinc-500">July 2026</p>
    <h1 class="mt-4 max-w-3xl text-5xl tracking-tight text-zinc-900 md:text-7xl">Summer Jamaica Outreach</h1>
    <p class="mt-6 max-w-2xl text-lg text-zinc-600">
      This mission focuses on kids in the under served community of Linstead, St. Catherine. When you give, you provide meals,
      clothing, essential school accessories and funds, as well as a careful access to truth that changes their lives.
    </p>
    <div class="mt-8 w-full max-w-2xl rounded-2xl border border-zinc-200 bg-white/90 p-5">
      <div class="flex items-center justify-between text-sm text-zinc-700">
        <span class="font-semibold tracking-wide text-zinc-900">Fundraising Goal: ${goalAmount.toLocaleString()}</span>
        <span>{progressPercent}% funded</span>
      </div>
      <div class="mt-3 h-2.5 overflow-hidden rounded-full bg-zinc-200">
        <div class="h-full rounded-full bg-[#5cd667]" style={`width: ${progressPercent}%`} />
      </div>
      <p class="mt-3 text-sm text-zinc-600">
        <span class="font-medium text-zinc-900">${raisedAmount.toLocaleString()}</span> raised •
        <span class="font-medium text-zinc-900"> ${remainingAmount.toLocaleString()}</span> to go
      </p>
    </div>
    <a href="/donate" class="mt-10 inline-flex rounded-full bg-zinc-900 px-7 py-3 text-sm font-semibold text-white transition hover:bg-zinc-700">
      Donate to the Mission
    </a>
  </section>

  <section class="content-shell py-24">
    <h2 class="text-3xl tracking-tight text-zinc-900">Fundraising Timeline</h2>
    <ol class="mt-8 space-y-5 border-l border-zinc-300 pl-6">
      <li><p class="text-sm uppercase tracking-[0.15em] text-zinc-500">January 2026</p><p class="mt-1 text-zinc-700">Launch campaign and sponsorship commitments.</p></li>
      <li><p class="text-sm uppercase tracking-[0.15em] text-zinc-500">March 2026</p><p class="mt-1 text-zinc-700">Community worship night and outreach fundraiser.</p></li>
      <li><p class="text-sm uppercase tracking-[0.15em] text-zinc-500">May 2026</p><p class="mt-1 text-zinc-700">Mission banquet and final giving push.</p></li>
      <li><p class="text-sm uppercase tracking-[0.15em] text-zinc-500">July 2026</p><p class="mt-1 text-zinc-700">Team departs for summer outreach in Jamaica.</p></li>
    </ol>
  </section>

  <section class="content-shell pb-24">
    <article class="rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm md:p-8">
      <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[#5cd667]">Upcoming Fundraiser</p>
      <h2 class="mt-2 text-3xl tracking-tight text-zinc-900">{mayFundraiserEvent.title}</h2>
      <p class="mt-2 text-sm text-zinc-600">{mayFundraiserEvent.dateLabel} • {mayFundraiserEvent.timeLabel}</p>
      <p class="text-sm text-zinc-600">{mayFundraiserEvent.location}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href={`tel:${mayFundraiserEvent.callPhoneHref}`} class="rounded bg-zinc-900 px-5 py-2.5 text-sm font-semibold text-white">Call to Preorder</a>
        <a href={mayFundraiserEvent.orderUrl} class="rounded border border-zinc-300 px-5 py-2.5 text-sm font-semibold text-zinc-700">Order Online</a>
      </div>
    </article>
  </section>
</BaseLayout>
