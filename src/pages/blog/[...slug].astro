---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MissionCtaBand from '../../components/MissionCtaBand.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} | JILBIT Blog`} description={post.data.description}>
  <section class="relative overflow-hidden bg-[#000000] px-6 py-14 text-left md:py-20">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(201,146,42,0.14),transparent_55%)]" />
    <div class="content-shell relative">
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-[#5cd667]">
        {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </p>
      <h1 class="mt-4 max-w-4xl text-4xl leading-tight text-[#faf7f2] md:text-5xl lg:text-6xl">{post.data.title}</h1>
      <p class="mt-6 max-w-3xl text-base text-[#faf7f2]/70 md:text-lg">{post.data.description}</p>
    </div>
  </section>

  <article class="bg-[#f0ebe0] px-6 py-16 md:py-20">
    <div class="content-shell">
      <div class="mx-auto max-w-3xl rounded-lg border border-[rgba(92,61,46,0.15)] bg-white p-8 shadow-sm md:p-12">
        <div
          class="prose-article space-y-6 text-lg leading-relaxed text-[#7a6658] [&_a]:text-[#2d4a3e] [&_a]:underline [&_a]:underline-offset-2 [&_h2]:mt-12 [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:text-[#2e1a0e] [&_h2]:first:mt-0 [&_li]:text-[#7a6658] [&_ol]:list-decimal [&_ol]:pl-6 [&_p]:leading-relaxed [&_strong]:text-[#2e1a0e] [&_ul]:list-disc [&_ul]:pl-6"
        >
          <Content />
        </div>
      </div>
    </div>
  </article>

  <MissionCtaBand />
</BaseLayout>
