---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MissionCtaBand from '../../components/MissionCtaBand.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const featuredPost = posts.find((post) => post.id === 'why-jamaica');
const remainingPosts = posts.filter((post) => post.id !== 'why-jamaica');
---

<BaseLayout title="JILBIT Blog" description="Stories, teachings, and ministry updates from JILBIT.">
  <section class="relative overflow-hidden bg-[#000000] px-6 py-16 text-left md:py-24">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(201,146,42,0.14),transparent_55%)]" />
    <div class="content-shell relative">
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-[#5cd667]">From the JILBIT desk</p>
      <h1 class="mt-4 max-w-4xl text-4xl leading-tight text-[#faf7f2] md:text-6xl">Blog</h1>
      <p class="mt-6 max-w-2xl text-base text-[#faf7f2]/70 md:text-lg">
        A focused feed of writings on faith, outreach, and practical discipleship.
      </p>
    </div>
  </section>

  <section class="bg-[#f0ebe0] px-6 py-16 md:py-20">
    <div class="content-shell">
      {featuredPost && (
        <article class="rounded-lg border border-[rgba(92,61,46,0.15)] bg-white p-6 shadow-sm md:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[#c9922a]">Featured post</p>
          <h2 class="mt-3 text-3xl leading-tight text-[#2e1a0e] md:text-4xl">
            <a href={`/blog/${featuredPost.id}/`} class="transition hover:text-[#c9922a]">{featuredPost.data.title}</a>
          </h2>
          <p class="mt-2 text-sm text-[#7a6658]">
            {featuredPost.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
          </p>
          <p class="mt-4 text-lg text-[#7a6658]">{featuredPost.data.description}</p>
        </article>
      )}

      {!featuredPost && (
        <article class="rounded-lg border border-[rgba(92,61,46,0.15)] bg-white p-6 shadow-sm md:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.14em] text-[#c9922a]">Featured post</p>
          <h2 class="mt-3 text-3xl leading-tight text-[#2e1a0e] md:text-4xl">
            <a href="/blog/why-jamaica/" class="transition hover:text-[#c9922a]">Why Jamaica</a>
          </h2>
          <p class="mt-2 text-sm text-[#7a6658]">Read why this mission starts in Linstead, Saint Catherine, Jamaica.</p>
        </article>
      )}

      <div class="mt-14 divide-y divide-[rgba(92,61,46,0.15)] border-y border-[rgba(92,61,46,0.15)]">
        {remainingPosts.map((post) => (
          <article class="py-8 md:py-10">
            <p class="text-sm text-[#7a6658]">{post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
            <h2 class="mt-2 text-2xl leading-snug text-[#2e1a0e] md:text-3xl">
              <a href={`/blog/${post.id}/`} class="transition hover:text-[#c9922a]">{post.data.title}</a>
            </h2>
            <p class="mt-3 max-w-3xl text-[#7a6658]">{post.data.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <MissionCtaBand heading="Read. Pray. Go." body="Stories are one way God prepares hearts — including yours — for the work of mission." />
</BaseLayout>
