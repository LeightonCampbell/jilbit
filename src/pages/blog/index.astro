---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
const featuredPost = posts.find((post) => post.id === 'why-jamaica');
const remainingPosts = posts.filter((post) => post.id !== 'why-jamaica');
---

<BaseLayout title="JILBIT Blog" description="Stories, teachings, and ministry updates from JILBIT.">
  <section class="content-shell py-24">
    <h1 class="text-4xl tracking-tight text-zinc-900 md:text-5xl">Blog</h1>
    <p class="mt-4 max-w-2xl text-zinc-600">A focused feed of writings on faith, outreach, and practical discipleship.</p>

    {featuredPost && (
      <article class="mt-10 rounded-3xl border border-zinc-200 bg-white p-7 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">Featured Post</p>
        <h2 class="mt-2 text-3xl tracking-tight text-zinc-900">
          <a href={`/blog/${featuredPost.id}/`} class="transition hover:text-zinc-600">{featuredPost.data.title}</a>
        </h2>
        <p class="mt-2 text-sm text-zinc-500">{featuredPost.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
        <p class="mt-3 text-zinc-600">{featuredPost.data.description}</p>
      </article>
    )}

    <div class="mt-12 divide-y divide-zinc-200 border-y border-zinc-200">
      {remainingPosts.map((post) => (
        <article class="py-7">
          <p class="text-sm text-zinc-500">{post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</p>
          <h2 class="mt-2 text-2xl text-zinc-900">
            <a href={`/blog/${post.id}/`} class="transition hover:text-zinc-600">{post.data.title}</a>
          </h2>
          <p class="mt-2 text-zinc-600">{post.data.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
